{
  "name": "koxxh-sound",
  "version": "1.0.0",
  "description": "Music player Koxxh Sound",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.koxxh.sound",
    "productName": "Koxxh Sound",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["ia32"]
        }
      ],
      "icon": "favicon.jpg",
      "artifactName": "Koxxh Sound Setup ${arch}.exe"
    },
}}
